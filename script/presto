fd . ~/dot --type f --no-ignore --hidden --exec sh -c '
  orig="${1#$HOME/dot}"
  parent="$(basename "$(dirname "$1")")/$(basename "$1")"
  for base in "$HOME" /etc /etc/xdg /usr/share $HOME/.local/share/ /usr/local/share; do
    for path in "$base$orig" "$base/$parent"; do
      if [ -f "$path" ]; then
        bak="$HOME/bak$orig"
        mkdir -p "$(dirname "$bak")"
        comm -13 <(sort "$path") <(sort "$1") >> "$bak"
        break 2
      fi
    done
  done
' _ {} \;
